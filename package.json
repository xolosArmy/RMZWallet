    "@walletconnect/core": "^2.23.4",
    "@walletconnect/web3wallet": "^1.16.1",
    "@x402-xec/axios": "0.1.0",
    "@x402-xec/core": "0.1.0",
    "@x402-xec/payments": "0.1.0",
    "@xolosarmy/tonalli-core": "github:xolosArmy/tonalli-core",
    "axios": "^1.7.0",
    "buffer": "^6.0.3",
    "chronik-client": "^3.5.0",
    "crypto-js": "^4.2.0",
